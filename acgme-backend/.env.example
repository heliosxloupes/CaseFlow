# Copy this to .env and fill in — NEVER commit .env to git

# Must match the JWT_SECRET in your Vercel environment variables
JWT_SECRET=your_jwt_secret_here

# 32-byte hex encryption key for ACGME passwords
# Generate with: npm run generate-key
ENCRYPTION_KEY=your_64_char_hex_key_here

# Railway Postgres connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/acgme_db

# Environment
NODE_ENV=production

# Set to 1 to log full ACGME Insert hidden field names and full error HTML on submit failure (verbose)
# ACGME_DEBUG_SUBMIT=1
#
# On submit 4xx/5xx, logs always include form key=value-lengths (no secrets) — compare to a manual
# browser POST on the same Insert page (DevTools → Network → Form Data) to debug without ACGME support.
#
# Optional: ACGME specialty id for GetCodes when Insert page has no SpecialtyId hidden field (default 158 = Plastic Surgery)
# ACGME_SPECIALTY_ID=158
#
# Procedure lookup uses GET /ads/CaseLogs/Code/GetCodes (codeDesc + activeAsOfDate) — same as ADS Insert UI.
# When a Payload row is returned, backend POSTs /ads/CaseLogs/Code/GetSelectedCodePartial (JSON body = row, like UI "Add") before Insert.
# Submit uses POST /ads/CaseLogs/CaseEntry/Insert (desktop Add Cases), not CaseEntryMobile/Insert.
